generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["nativeDistinct", "relationJoins"]
  engineType      = "client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["parkhaus"]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Adresse {
  id          Int      @id @default(autoincrement())
  plz         String
  ort         String
  strasse     String
  hausnummer  String
  parkhausId  Int       @unique @map("parkhaus_id")
  parkhaus    Parkhaus  @relation(fields: [parkhausId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("parkhaus")
  @@map("adresse")
}

model Auto {
  id            Int       @id @default(autoincrement())
  kennzeichen   String
  einfahrtszeit DateTime  @db.Timestamp(6)
  kundentyp     Kundentyp
  parkhausId    Int       @map("parkhaus_id")
  parkhaus      Parkhaus  @relation(fields: [parkhausId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([parkhausId])
  @@schema("parkhaus")
  @@map("auto")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Parkhaus {
  id               Int            @id @default(autoincrement())
  version          Int            @default(0)
  name             String         @unique
  kapazitaet       Int
  tarifProStunde   Decimal        @db.Decimal(8, 2) @map("tarif_pro_stunde")
  erzeugt          DateTime       @default(now()) @db.Timestamp(6)
  aktualisiert     DateTime       @default(now()) @db.Timestamp(6) @updatedAt
  adresse          Adresse?
  autos            Auto[]
  parkhausFile     ParkhausFile?

  @@schema("parkhaus")
  @@map("parkhaus")
}

model ParkhausFile {
  id          Int      @id @default(autoincrement())
  data        Bytes
  filename    String
  mimetype    String?
  parkhausId  Int      @unique @map("parkhaus_id")
  parkhaus    Parkhaus @relation(fields: [parkhausId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([parkhausId])
  @@schema("parkhaus")
  @@map("parkhaus_file")
}

enum Kundentyp {
  PREMIUM
  BASIS
  ANWOHNER

  @@schema("parkhaus")
  @@map("kundentyp")
}
